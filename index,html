<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cohabitation Matchmaking</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins', sans-serif; }
    body { background:#f7f9fc; color:#333; }

    header {
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:20px 40px;
      background:white;
      box-shadow:0 5px 15px rgba(0,0,0,0.05);
    }

    header h1 { color:#4facfe; }

    nav a {
      margin-left:20px;
      text-decoration:none;
      color:#333;
      font-weight:500;
    }

    .hero {
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:80px 40px;
      background:linear-gradient(120deg,#4facfe,#00f2fe);
      color:white;
      flex-wrap:wrap;
    }

    .hero-text { max-width:500px; }

    .hero h2 { font-size:40px; margin-bottom:15px; }

    .hero p { margin-bottom:20px; line-height:1.6; }

    .hero button {
      padding:12px 25px;
      border:none;
      border-radius:30px;
      background:white;
      color:#4facfe;
      font-weight:600;
      cursor:pointer;
    }

    .hero img {
      width:400px;
      max-width:100%;
    }

    .container {
      max-width:1100px;
      margin:60px auto;
      padding:0 20px;
    }

    .section { margin-bottom:60px; text-align:center; }

    .section h2 { margin-bottom:15px; color:#2c3e50; }

    .features {
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:20px;
      margin-top:30px;
    }

    .card {
      background:white;
      padding:25px;
      border-radius:15px;
      box-shadow:0 10px 20px rgba(0,0,0,0.05);
      transition:0.3s;
    }

    .card:hover { transform:translateY(-8px); }

    .steps {
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:20px;
      margin-top:30px;
    }

    .cta {
      text-align:center;
      padding:60px 20px;
      background:#4facfe;
      color:white;
      border-radius:15px;
    }

    .cta button {
      margin-top:15px;
      padding:12px 25px;
      border:none;
      border-radius:30px;
      background:white;
      color:#4facfe;
      font-weight:600;
      cursor:pointer;
    }

    footer {
      text-align:center;
      padding:20px;
      color:#777;
      font-size:14px;
    }

    @media(max-width:768px) {
      .hero { flex-direction:column; text-align:center; }
    }
  </style>
</head>
<body>

<header>
  <h1>CoHabit</h1>
  <nav>
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Sign Up</a>
    <a href="#">Login</a>
  </nav>
</header>

<section class="hero">
  <div class="hero-text">
    <h2>Find Your Perfect Roommate</h2>
    <p>Match with people who share your lifestyle, habits, and preferences. Make co-living simple, safe, and enjoyable.</p>
    <button>Get Started</button>
  </div>
  <img src="https://via.placeholder.com/400" alt="Hero Image">
</section>

<div class="container">

  <div class="section">
    <h2>Why Choose Us</h2>
    <div class="features">
      <div class="card">
        <h3>Smart Matching</h3>
        <p>Advanced algorithm connects you with compatible roommates.</p>
      </div>

      <div class="card">
        <h3>Secure Platform</h3>
        <p>Your safety is our priority with verified profiles.</p>
      </div>

      <div class="card">
        <h3>Easy Communication</h3>
        <p>Chat with potential matches before deciding.</p>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>How It Works</h2>
    <div class="steps">
      <div class="card">
        <h3>1. Create Profile</h3>
        <p>Sign up and tell us about your lifestyle.</p>
      </div>

      <div class="card">
        <h3>2. Get Matches</h3>
        <p>Receive roommate suggestions tailored to you.</p>
      </div>

      <div class="card">
        <h3>3. Connect</h3>
        <p>Start conversations and find your ideal match.</p>
      </div>
    </div>
  </div>

  <div class="cta">
    <h2>Start Your Journey Today</h2>
    <button>Join Now</button>
  </div>

</div>

<footer>
  <p>© 2026 CoHabit. All rights reserved.</p>
</footer>

</body>
</html>
